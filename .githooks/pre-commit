#!/bin/sh
# Spotless 포맷 검증 — 위반 시 커밋 차단
echo "커밋 전 포맷 검증 중 (spotlessCheck)..."
./gradlew spotlessCheck -q 2>/dev/null
if [ $? -ne 0 ]; then
  echo ""
  echo "포맷 위반이 발견되었습니다."
  echo "./gradlew spotlessApply 를 실행한 뒤 다시 커밋하세요."
  exit 1
fi

# application-secrets.yml 암호화 검증 — 평문 값 커밋 차단
SECRETS_FILE="app/src/main/resources/application-secrets.yml"
if git diff --cached --name-only | grep -qF "$SECRETS_FILE"; then
  echo "application-secrets.yml 암호화 검증 중..."
  UNENCRYPTED=$(git show ":$SECRETS_FILE" \
    | grep -nE '^\s*[^#][^:]*:\s+\S' \
    | grep -v 'ENC(' \
    | grep -vE 'on-profile:\s+\S' \
    | grep -vE ':\s+(true|false|null|[0-9]+)\s*$')
  if [ -n "$UNENCRYPTED" ]; then
    echo ""
    echo "[ERROR] application-secrets.yml에 암호화되지 않은 값이 있습니다:"
    echo "$UNENCRYPTED"
    echo ""
    echo "모든 민감한 값은 Jasypt ENC(...) 형식으로 암호화해야 합니다."
    exit 1
  fi
  echo "application-secrets.yml 암호화 검증 완료."
fi
